# Module 11: Memory Bank Agent Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# GOOGLE CLOUD CONFIGURATION (REQUIRED)
# =============================================================================

# Your Google Cloud Project ID
# Find it in: https://console.cloud.google.com/
GOOGLE_CLOUD_PROJECT=your-project-id

# Google Cloud Region for Vertex AI
# Supported regions: us-central1, europe-west1, asia-northeast1
# See: https://cloud.google.com/vertex-ai/docs/general/locations
GOOGLE_CLOUD_LOCATION=us-central1

# =============================================================================
# AGENT ENGINE CONFIGURATION (REQUIRED)
# =============================================================================

# Agent Engine ID for Memory Bank
# This is the ID of your Agent Engine instance (NOT the full resource name)
# Example: If your Agent Engine resource name is:
#   projects/my-project/locations/us-central1/reasoningEngines/123456789
# Then your AGENT_ENGINE_ID is: 123456789
#
# To create an Agent Engine instance, see: SETUP_GCP.md
AGENT_ENGINE_ID=your-agent-engine-id

# =============================================================================
# MODEL CONFIGURATION (OPTIONAL)
# =============================================================================

# Gemini model to use for the agent
# Options: gemini-2.5-flash, gemini-2.0-flash, gemini-2.0-pro
MODEL=gemini-2.5-flash

# =============================================================================
# NOTES
# =============================================================================
#
# Before running this module, you must:
# 1. Create a Google Cloud Project
# 2. Enable Vertex AI API
# 3. Create an Agent Engine instance
# 4. Set up authentication (gcloud auth application-default login)
#
# See SETUP_GCP.md for detailed instructions.
#
