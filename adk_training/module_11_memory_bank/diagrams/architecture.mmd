graph TB
    subgraph "Twoja Aplikacja (Local/Cloud Run/GKE)"
        User[👤 Użytkownik]
        Agent[🤖 Chronicler Agent<br/>LlmAgent]
        Runner[🏃 ADK Runner]
        Tools[🔧 Memory Tools<br/>PreloadMemoryTool<br/>LoadMemoryTool]
        Callback[⚡ Callback<br/>auto_save_session_to_memory]
    end
    
    subgraph "ADK Services"
        MemService[💾 VertexAiMemoryBankService<br/>project + location + agent_engine_id]
        SessService[📝 SessionService<br/>InMemory/VertexAi]
    end
    
    subgraph "Google Cloud Platform"
        subgraph "Vertex AI Agent Engine"
            AgentEngine[🏗️ Agent Engine Instance<br/>ID: 1234567890]
            MemBank[(☁️ Memory Bank<br/>Vector Database)]
            API[🔌 Vertex AI API<br/>GenerateMemories<br/>RetrieveMemories]
        end
    end
    
    User -->|"Pytanie"| Runner
    Runner --> Agent
    Agent -->|"Na początku tury"| Tools
    Tools -->|"search_memory()"| MemService
    MemService -->|"RetrieveMemories"| API
    API --> MemBank
    MemBank -->|"Relevant memories"| API
    API -->|"Memories"| MemService
    MemService -->|"Context"| Tools
    Tools -->|"Loaded memories"| Agent
    Agent -->|"Odpowiedź"| Runner
    Runner -->|"Odpowiedź"| User
    Agent -->|"Po odpowiedzi"| Callback
    Callback -->|"add_events_to_memory()"| MemService
    MemService -->|"GenerateMemories"| API
    API -->|"Extract & Store"| MemBank
    
    Runner -.->|"Używa"| SessService
    Runner -.->|"Używa"| MemService
    
    style MemBank fill:#34a853,color:#fff
    style Agent fill:#ff6b6b,color:#fff
    style MemService fill:#4a90e2,color:#fff
    style AgentEngine fill:#fbbc04,color:#000

