# Google ADK
GOOGLE_API_KEY=your_google_api_key
ADK_MODEL=gemini-2.5-flash
ADK_MODEL_PRO=gemini-2.5-pro

# Comarch MCP server URL (MCP_MODE=streamable-http, default port 3000)
MCP_SERVER_URL=http://localhost:3000

# Comarch MCP — Jira (set in MCP server env, not here — see startup command)
JIRA_BASE_URL=https://jira.services.comarch.com/rest/api/2
JIRA_BEARER_TOKEN=your_jira_bearer_token

# Comarch MCP — Confluence/Wiki
WIKI_BASE_URL=https://wiki.comarch/rest/api
WIKI_BEARER_TOKEN=your_wiki_bearer_token

