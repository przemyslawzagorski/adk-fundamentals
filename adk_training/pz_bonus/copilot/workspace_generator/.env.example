# Google Cloud / Gemini API Configuration
GOOGLE_API_KEY=your-api-key-here
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Model Configuration
ADK_MODEL_PRO=gemini-2.5-pro
ADK_MODEL_FLASH=gemini-2.5-flash

# Feature Flags

# 🔄 Retry Logic (Exponential Backoff)
# Automatyczne retry na 429 RESOURCE_EXHAUSTED errors
# Zalecane: true (dla stabilności)
USE_RETRY_LOGIC=true

# 🧠 BuiltInPlanner (Thinking Mode)
# Włącza thinking mode dla Planning agentów
# Zalecane: true (dla jakości), false (dla szybkości/limitów)
# UWAGA: Thinking mode = więcej requestów do API!
USE_BUILTIN_PLANNER=false

# Logging
LOG_LEVEL=INFO

