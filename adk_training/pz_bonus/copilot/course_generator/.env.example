# 🎓 GitHub Copilot Course Generator - Environment Variables

# ============================================================
# GOOGLE AI / GEMINI API
# ============================================================
# Required: Get your API key from https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Optional: Specify models (defaults shown)
ADK_MODEL_PRO=gemini-2.5-pro
ADK_MODEL_FLASH=gemini-2.5-flash

# ============================================================
# FEATURE FLAGS
# ============================================================
# Enable thinking mode (BuiltInPlanner) - slower but better quality
USE_BUILTIN_PLANNER=true

# ============================================================
# GITHUB API (Optional)
# ============================================================
# Optional: GitHub token for higher rate limits when searching repos
# Get token from https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# ============================================================
# OUTPUT CONFIGURATION
# ============================================================
# Output directory for generated course materials
OUTPUT_DIR=./output/copilot_training

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

