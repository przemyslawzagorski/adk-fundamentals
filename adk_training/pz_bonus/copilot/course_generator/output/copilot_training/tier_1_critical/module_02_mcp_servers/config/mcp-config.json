{
  "mcpServers": [
    {
      "id": "spring-petclinic-jira-provider",
      "name": "Spring PetClinic Jira Integrator",
      "description": "MCP Server do zarządzania zadaniami Jira w kontekście spring-petclinic.",
      "url": "http://localhost:3000/api/jira",
      "api_key_env_var": "PETCLINIC_JIRA_API_KEY",
      "enabled": true,
      "capabilities": [
        {
          "id": "create-issue",
          "description": "Tworzy nowe zadanie w Jira.",
          "input_schema": {
            "type": "object",
            "properties": {
              "summary": {"type": "string", "description": "Krótki opis problemu"},
              "description": {"type": "string", "description": "Szczegółowy opis zadania/błędu"},
              "module": {"type": "string", "enum": ["Owner", "Pet", "Vet", "Visit", "Global"], "description": "Moduł spring-petclinic, którego dotyczy zadanie"},
              "priority": {"type": "string", "enum": ["Niski", "Średni", "Wysoki", "Najwyższy"], "description": "Priorytet zadania"},
              "assignee": {"type": "string", "description": "Osoba przypisana do zadania"}
            },
            "required": ["summary", "description", "module", "priority"]
          }
        }
      ]
    },
    {
      "id": "spring-petclinic-code-analyzer",
      "name": "Spring PetClinic Code Analyzer",
      "description": "MCP Server do analizy kodu i sugerowania usprawnień w spring-petclinic.",
      "url": "http://localhost:3001/api/analyzer",
      "api_key_env_var": "PETCLINIC_ANALYZE_API_KEY",
      "enabled": true,
      "capabilities": [
        {
          "id": "analyze-file",
          "description": "Analizuje wskazany plik pod kątem best practices i potencjalnych problemów.",
          "input_schema": {
            "type": "object",
            "properties": {
              "filePath": {"type": "string", "description": "Ścieżka do pliku do analizy"},
              "ruleset": {"type": "string", "enum": ["performance", "security", "maintainability"], "description": "Zestaw reguł analizy"}
            },
            "required": ["filePath", "ruleset"]
          }
        }
      ]
    }
  ]
}