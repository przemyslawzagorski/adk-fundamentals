{
  "copilot_module_config": {
    "module_id": "module_01_tryb_agent",
    "module_name": "Tryb Agent - Fundament Pracy z Copilot",
    "version": "1.0.0",
    "enabled_features": [
      "agent_planning",
      "context_awareness",
      "tool_orchestration"
    ],
    "preferred_agents": {
      "refactoring": "@agent",
      "code_analysis": "@workspace",
      "external_search": "@search"
    },
    "prompt_suggestions": [
      "refactor_to_service_layer",
      "generate_unit_tests",
      "add_rest_endpoint",
      "explain_code_security"
    ],
    "default_context_limit_tokens": 8000,
    "security_scan_on_generate": true,
    "code_style_guide": "google_java_format",
    "documentation_template": "javadoc_standard"
  },
  "training_specific_settings": {
    "target_repository": "spring-projects/spring-petclinic",
    "training_level": "advanced",
    "language": "pl-PL"
  }
}