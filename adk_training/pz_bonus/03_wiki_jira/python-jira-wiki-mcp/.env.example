# ============================================================
# MCP Jira & Wiki Server - Konfiguracja środowiskowa
# ============================================================
# INSTRUKCJA: Skopiuj ten plik jako .env i uzupełnij wartości
#   cp .env.example .env   (Linux/Mac)
#   copy .env.example .env (Windows)
# ============================================================

# --- Jira Configuration (WYMAGANE) ---
# Format URL dla Atlassian Cloud: https://TWOJA-INSTANCJA.atlassian.net/rest/api/2
JIRA_BASE_URL=https://TWOJA-INSTANCJA.atlassian.net/rest/api/2

# Typ autoryzacji: "basic" (Atlassian Cloud) lub "bearer" (on-premise/PAT)
JIRA_AUTH_TYPE=basic

# Dla basic auth (Atlassian Cloud):
JIRA_USER_EMAIL=twoj-email@example.com
JIRA_API_TOKEN=twoj-api-token-z-atlassian

# Dla bearer auth (on-premise):
# JIRA_BEARER_TOKEN=twoj-bearer-token

# --- Jira Defaults (Opcjonalne - do tworzenia ticketów) ---
JIRA_DEFAULT_PROJECT_KEY=TRAIN
JIRA_DEFAULT_ISSUE_TYPE=Task
JIRA_DEFAULT_LABEL=mcp-training

# --- Wiki / Confluence (Opcjonalne) ---
ENABLE_WIKI_INTEGRATION=true

# Format URL dla Atlassian Cloud: https://TWOJA-INSTANCJA.atlassian.net/wiki/rest/api
WIKI_BASE_URL=https://TWOJA-INSTANCJA.atlassian.net/wiki/rest/api

# Typ autoryzacji: "basic" (Atlassian Cloud) lub "bearer" (on-premise/PAT)
WIKI_AUTH_TYPE=basic

# Dla basic auth (Atlassian Cloud) - te same dane co Jira:
WIKI_USER_EMAIL=twoj-email@example.com
WIKI_API_TOKEN=twoj-api-token-z-atlassian

# Dla bearer auth (on-premise):
# WIKI_BEARER_TOKEN=twoj-bearer-token

