# =============================================================================
# Module 1: Hello World Agent - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# DO NOT commit .env files to version control!
# =============================================================================

# Google Cloud Project ID
# Find this in the GCP Console or run: gcloud config get-value project
GOOGLE_CLOUD_PROJECT=your-project-id

# Google Cloud Region (optional - defaults to us-central1)
# Common options: us-central1, europe-west1, asia-east1
GOOGLE_CLOUD_LOCATION=us-central1

# =============================================================================
# Authentication Options (choose one):
# =============================================================================

# Option 1: Application Default Credentials (recommended for development)
# Run: gcloud auth application-default login
# No additional configuration needed after running the command

# Option 2: Service Account Key File (for production/CI)
# Download a service account key from GCP Console and set the path:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account-key.json

# =============================================================================
# Verification Steps:
# =============================================================================
# 1. Ensure Vertex AI API is enabled in your project
# 2. Run: gcloud auth application-default login
# 3. Test: python -c "from google.adk.agents import LlmAgent; print('Success!')"
