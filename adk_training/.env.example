# Google Cloud Configuration
# Skopiuj ten plik jako .env i wypełnij swoimi wartościami

# Wymagane dla wszystkich modułów
GOOGLE_GENAI_USE_VERTEXAI=1
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Opcjonalne - Module 03: RAG Agent (Vertex AI Search)
# Odkomentuj i wypełnij jeśli chcesz testować Module 03
# SEARCH_ENGINE_ID=your-search-engine-id
# SEARCH_DATASTORE_ID=your-datastore-id


