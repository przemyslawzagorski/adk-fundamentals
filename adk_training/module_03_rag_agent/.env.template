# Module 3: RAG Agent - Environment Configuration
# ================================================
# Copy this file to .env and configure your values

# =============================================================================
# REQUIRED: Google Cloud Configuration
# =============================================================================
# Your Google Cloud Project ID
GOOGLE_CLOUD_PROJECT=your-project-id

# Region for Vertex AI (e.g., us-central1, europe-west1)
GOOGLE_CLOUD_LOCATION=us-central1

# =============================================================================
# VERTEX AI SEARCH CONFIGURATION (Choose ONE option)
# =============================================================================
# You must configure EITHER search_engine_id OR data_store_id (not both!)

# Option 1: Search Engine ID (Recommended for Search Apps)
# Format: projects/{project}/locations/{location}/collections/default_collection/engines/{engine_id}
SEARCH_ENGINE_ID=projects/your-project-id/locations/global/collections/default_collection/engines/your-engine-id

# Option 2: Data Store ID (Direct data store access)
# Format: projects/{project}/locations/{location}/collections/default_collection/dataStores/{datastore_id}
# SEARCH_DATASTORE_ID=projects/your-project-id/locations/global/collections/default_collection/dataStores/your-datastore-id

# =============================================================================
# SETUP INSTRUCTIONS
# =============================================================================
# 1. Go to Google Cloud Console > Vertex AI > Search & Conversation
# 2. Create a new App (search type)
# 3. Create a Data Store and upload your documents
# 4. Copy the Engine ID or Data Store ID to this file
# 5. Wait for indexing to complete before testing
#
# Documentation: https://cloud.google.com/generative-ai-app-builder/docs

