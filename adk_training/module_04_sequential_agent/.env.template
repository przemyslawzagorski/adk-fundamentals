# =============================================================================
# Module 4: Sequential Multi-Agent - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values

# Google Cloud Project ID (required)
GOOGLE_CLOUD_PROJECT=your-project-id

# Google Cloud Region (required)
GOOGLE_CLOUD_LOCATION=us-central1

# Model to use (optional, defaults to gemini-2.5-flash)
ADK_MODEL=gemini-2.5-flash

# =============================================================================
# Authentication Notes
# =============================================================================
# Option 1: Use Application Default Credentials (recommended for development)
#   Run: gcloud auth application-default login
#
# Option 2: Service Account Key (for production)
#   GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

